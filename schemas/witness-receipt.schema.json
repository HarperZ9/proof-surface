{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harperz9.github.io/proof-surface/witness-receipt.schema.json",
  "title": "Witness Receipt (EMET mirror)",
  "description": "Consumer-side mirror of EMET's witness-receipt shape. EMET stays self-contained (not a dependency); this schema lets tools validate EMET receipts. The verdict is confined to EMET's closed lattice (witness facts only); authority tokens are forbidden.",
  "type": "object",
  "additionalProperties": false,
  "required": ["receipt_id", "verdict", "witness", "subject", "evidence"],
  "properties": {
    "receipt_id": { "type": "string", "minLength": 1 },
    "verdict": {
      "enum": [
        "MATCH",
        "DRIFT",
        "UNVERIFIABLE",
        "COHERENT",
        "VIEW_DIFFERS_FROM_SOURCE",
        "CORROBORATED",
        "QUARANTINE_READ_PATH_DIVERGENCE"
      ]
    },
    "witness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["implementation", "spec_version", "self_sha256", "check"],
      "properties": {
        "implementation": { "type": "string", "minLength": 1 },
        "spec_version": { "type": "string", "minLength": 1 },
        "self_sha256": { "type": "string", "minLength": 1 },
        "check": { "type": "string", "minLength": 1 }
      }
    },
    "subject": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "digest"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "digest": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sha256"],
            "properties": {
              "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exit_code", "stdout_verdict_line"],
      "properties": {
        "exit_code": { "type": "integer" },
        "stdout_verdict_line": { "type": "string" }
      }
    },
    "notes": { "type": "string" }
  }
}
